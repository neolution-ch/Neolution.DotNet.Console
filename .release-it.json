{
  "git": {
    "push": true
  },
  "npm": {
    "publish": false,
    "skipChecks": true
  },
  "github": {
    "release": true,
    "releaseName": "Release ${version}",
    "releaseNotes": "auto"
  },
  "plugins": {
    "@release-it/keep-a-changelog": {
      "filename": "CHANGELOG.md",
      "strictLatest": false,
      "addUnreleased": true,
      "head": "Unreleased",
      "keepUnreleased": "${preRelease}"
    }
  },
  "hooks": {
  }
}